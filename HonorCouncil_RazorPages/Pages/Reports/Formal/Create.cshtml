@page
@model HonorCouncil_RazorPages.Pages.Reports.Formal.CreateModel
@{
    ViewData["Title"] = "Formal report";
    var reportDateValue = Model.Input.ReportDate == default ? DateTime.Today : Model.Input.ReportDate;
    var earliestViolationDate = DateTime.Today.AddDays(-90).ToString("yyyy-MM-dd");
}

<style>
    .formal-report-shell {
        background: #ededed;
        padding: 2.5rem 1rem 4rem;
        min-height: calc(100vh - 80px);
    }

    .formal-report-document {
        max-width: 860px;
        margin: 0 auto;
        background: #f9f9f9;
        border: 2px solid #6d6d6d;
        padding: 1.5rem 1.6rem 2.5rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        color: #171717;
    }

    .formal-report-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #9b9b9b;
        margin-bottom: 1.35rem;
    }

    .formal-report-school {
        margin: 0 0 0.75rem;
        font-size: 1.2rem;
        font-weight: 700;
        color: #1f1f1f;
    }

    .formal-report-title {
        margin: 0;
        color: #4b2e83;
        font-size: 2.1rem;
        line-height: 1.05;
        font-weight: 800;
    }

    .formal-report-logo {
        min-width: 165px;
        text-align: right;
        color: #2d2d2d;
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.7rem;
        margin-top: 0.3rem;
    }

    .formal-report-logo-mark {
        width: 54px;
        height: 54px;
        border: 2px solid #2d2d2d;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 0.08em;
    }

    .formal-report-logo-text {
        font-size: 0.95rem;
        line-height: 1.05;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .formal-report-alert {
        margin: 0 0 1rem;
        color: #8b1e1e;
        font-weight: 600;
    }

    .formal-report-validation {
        margin-bottom: 1rem;
        color: #b42318;
        font-size: 0.95rem;
    }

    .formal-report-section {
        padding: 1rem 0 1.25rem;
        border-bottom: 1px solid #a5a5a5;
    }

    .formal-report-section:last-of-type {
        border-bottom: none;
    }

    .formal-report-section h2 {
        margin: 0 0 1rem;
        font-size: 1.55rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #111;
        letter-spacing: 0.01em;
    }

    .formal-report-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem 1.2rem;
    }

    .formal-report-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .formal-report-field.full {
        grid-column: 1 / -1;
    }

    .formal-report-label {
        font-size: 1rem;
        font-weight: 500;
        color: #1f1f1f;
    }

    .formal-report-input,
    .formal-report-textarea {
        width: 100%;
        border: 2px solid #7b7b7b;
        border-radius: 0.5rem;
        background: #fff;
        padding: 0.72rem 0.9rem;
        font-size: 0.98rem;
        color: #1d1d1d;
        box-sizing: border-box;
    }

    .formal-report-input[readonly] {
        background: #f2f2f2;
        color: #4b4b4b;
    }

    .formal-report-textarea {
        min-height: 96px;
        resize: vertical;
    }

    .formal-report-radio-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1.2rem 1.8rem;
        padding-top: 0.2rem;
    }

    .formal-report-radio-row label {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.98rem;
        font-weight: 500;
    }

    .formal-report-rule {
        margin: 0.2rem 0 0;
        color: #d92d20;
        font-size: 0.95rem;
        font-weight: 500;
    }

    .formal-report-rule-error {
        margin: 0.45rem 0 0;
        color: #b42318;
        font-size: 0.95rem;
        font-weight: 700;
    }

    .formal-report-witness-copy {
        margin: 0 0 0.9rem;
        font-size: 1rem;
        line-height: 1.35;
    }

    .formal-report-witness-grid {
        display: grid;
        grid-template-columns: 72px 1fr;
        gap: 0.85rem 1rem;
        margin-bottom: 1.15rem;
    }

    .formal-report-witness-grid:last-child {
        margin-bottom: 0;
    }

    .formal-report-line-label {
        font-weight: 500;
        align-self: center;
    }

    .formal-report-underline {
        border: 2px solid #7b7b7b;
        border-radius: 0.5rem;
        background: #fff;
        padding: 0.72rem 0.9rem;
        font-size: 0.98rem;
        width: 100%;
        box-sizing: border-box;
    }

    .formal-report-routing-title,
    .formal-report-contact-title {
        margin: 0 0 0.55rem;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .formal-report-copy {
        margin: 0 0 1rem;
        line-height: 1.45;
        font-size: 0.98rem;
    }

    .formal-report-office-box {
        margin-top: 1rem;
        background: #efefef;
        border: 2px solid #8d8d8d;
        padding: 1rem 1.25rem 1.1rem;
        max-width: 720px;
    }

    .formal-report-office-box h3 {
        margin: 0 0 0.75rem;
        font-size: 1rem;
        font-weight: 800;
    }

    .formal-report-office-line {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.75rem;
        align-items: center;
        margin-bottom: 0.55rem;
        font-size: 0.95rem;
    }

    .formal-report-office-line:last-child {
        margin-bottom: 0;
    }

    .formal-report-office-fill {
        border-bottom: 2px solid #7d7d7d;
        min-height: 12px;
    }

    .formal-report-actions {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        max-width: 620px;
        margin: 2rem auto 0;
    }

    .formal-report-button {
        min-width: 190px;
        padding: 0.82rem 1.2rem;
        border-radius: 0.55rem;
        border: 2px solid #7a7a7a;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
    }

    .formal-report-button-secondary {
        background: #fff;
        color: #222;
    }

    .formal-report-button-primary {
        background: #fff;
        color: #111;
    }

    .field-validation-error,
    .text-danger {
        color: #b42318;
        font-size: 0.9rem;
    }

    @@media (max-width: 820px) {
        .formal-report-document {
            padding: 1.2rem 1rem 2rem;
        }

        .formal-report-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .formal-report-logo {
            justify-content: flex-start;
            text-align: left;
        }

        .formal-report-grid {
            grid-template-columns: 1fr;
        }

        .formal-report-actions {
            flex-direction: column;
            max-width: none;
        }

        .formal-report-button {
            width: 100%;
        }
    }
</style>

<section class="formal-report-shell">
    <article class="formal-report-document">
        <header class="formal-report-header">
            <div>
                <p class="formal-report-school">James Madison University</p>
                <h1 class="formal-report-title">Formal Honor Code<br />Violation Report Form</h1>
            </div>

            <div class="formal-report-logo" aria-label="James Madison University">
                <div class="formal-report-logo-mark">JMU</div>
                <div class="formal-report-logo-text">James<br />Madison<br />University</div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.AlertMessage))
        {
            <p class="formal-report-alert">@Model.AlertMessage</p>
        }

        <form method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="formal-report-validation"></div>

            <section class="formal-report-section">
                <h2>I. Faculty Information</h2>

                <div class="formal-report-grid">
                    <div class="formal-report-field full">
                        <label asp-for="Input.FacultyName" class="formal-report-label">Faculty Name</label>
                        <input asp-for="Input.FacultyName" class="formal-report-input" placeholder="Full name" />
                        <span asp-validation-for="Input.FacultyName" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.FacultyDepartment" class="formal-report-label">Office</label>
                        <input asp-for="Input.FacultyDepartment" class="formal-report-input" placeholder="Office / department" />
                    </div>

                    <div class="formal-report-field">
                        <label class="formal-report-label">Date</label>
                        <input type="text" class="formal-report-input" value="@reportDateValue.ToString("MM/dd/yyyy")" readonly />
                        <input asp-for="Input.ReportDate" type="hidden" />
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.FacultyPhone" class="formal-report-label">Phone</label>
                        <input asp-for="Input.FacultyPhone" class="formal-report-input" placeholder="(XXX) XXX-XXXX" />
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.FacultyEmail" class="formal-report-label">Faculty E-mail</label>
                        <input asp-for="Input.FacultyEmail" class="formal-report-input" placeholder="@@jmu.edu" />
                        <span asp-validation-for="Input.FacultyEmail" class="text-danger"></span>
                    </div>
                </div>
            </section>

            <section class="formal-report-section">
                <h2>II. Course Information</h2>

                <div class="formal-report-grid">
                    <div class="formal-report-field">
                        <label asp-for="Input.CourseName" class="formal-report-label">Course Title</label>
                        <input asp-for="Input.CourseName" class="formal-report-input" placeholder="Full course name" />
                        <span asp-validation-for="Input.CourseName" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.CourseCode" class="formal-report-label">Course Number</label>
                        <input asp-for="Input.CourseCode" class="formal-report-input" placeholder="e.g. CIS 484" />
                        <span asp-validation-for="Input.CourseCode" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.Term" class="formal-report-label">Semester</label>
                        <input asp-for="Input.Term" class="formal-report-input" placeholder="e.g. Spring 2026" />
                    </div>

                    <div class="formal-report-field">
                        <span class="formal-report-label">Course Format</span>
                        <div class="formal-report-radio-row">
                            <label>
                                <input asp-for="Input.CourseFormat" type="radio" value="Online" />
                                Online
                            </label>
                            <label>
                                <input asp-for="Input.CourseFormat" type="radio" value="In-person" />
                                In-person
                            </label>
                        </div>
                    </div>
                </div>
            </section>

            <section class="formal-report-section">
                <h2>III. Student Information</h2>

                <div class="formal-report-grid">
                    <div class="formal-report-field">
                        <label asp-for="Input.StudentName" class="formal-report-label">Student Name</label>
                        <input asp-for="Input.StudentName" class="formal-report-input" placeholder="e.g. John Doe" />
                        <span asp-validation-for="Input.StudentName" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.StudentNumber" class="formal-report-label">Student ID Number</label>
                        <input asp-for="Input.StudentNumber" class="formal-report-input" placeholder="eid number" />
                        <span asp-validation-for="Input.StudentNumber" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field full">
                        <span class="formal-report-label">Year</span>
                        <div class="formal-report-radio-row">
                            @foreach (var year in new[] { "Freshman", "Sophomore", "Junior", "Senior", "Graduate student" })
                            {
                                <label>
                                    <input asp-for="Input.StudentAcademicYear" type="radio" value="@year" />
                                    @year
                                </label>
                            }
                        </div>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.StudentEmail" class="formal-report-label">Student E-mail</label>
                        <input asp-for="Input.StudentEmail" class="formal-report-input" placeholder="@@dukes.jmu.edu" />
                        <span asp-validation-for="Input.StudentEmail" class="text-danger"></span>
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.StudentPhone" class="formal-report-label">Student Phone</label>
                        <input asp-for="Input.StudentPhone" class="formal-report-input" placeholder="(XXX) XXX-XXXX" />
                    </div>
                </div>
            </section>

            <section class="formal-report-section">
                <h2>IV. Violation Information</h2>

                <div class="formal-report-grid">
                    <div class="formal-report-field">
                        <label asp-for="Input.PossibleViolationDate" class="formal-report-label">Date of Possible Honor Code Violation</label>
                        <input asp-for="Input.PossibleViolationDate" type="date" class="formal-report-input" />
                    </div>

                    <div class="formal-report-field">
                        <label asp-for="Input.ViolationDate" class="formal-report-label">Date of Occurrence of Possible Honor Code Violation</label>
                        <input asp-for="Input.ViolationDate"
                               type="date"
                               class="formal-report-input"
                               min="@earliestViolationDate"
                               data-window-message="Reports must be filed within 90 days of the violation date." />
                        <span asp-validation-for="Input.ViolationDate" class="text-danger"></span>
                    </div>
                </div>

                <p class="formal-report-rule">
                    This report must be submitted to the Honor council within <strong>90 days</strong> of the occurrence of the violation.
                </p>

                @if (!Model.IsWithinWindow)
                {
                    <p class="formal-report-rule-error">
                        Invalid date. Formal reports must be filed within 90 days of the occurrence.
                    </p>
                }

                <div class="formal-report-field" style="margin-top: 1rem;">
                    <label asp-for="Input.Description" class="formal-report-label">Description of Possible Violation</label>
                    <textarea asp-for="Input.Description" rows="4" class="formal-report-textarea" placeholder="Describe what occurred..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>
            </section>

            <section class="formal-report-section">
                <p class="formal-report-witness-copy">
                    Names of other individuals who might have information regarding the possible Honor Code violation:
                </p>

                @for (var i = 0; i < Model.Input.Witnesses.Count; i++)
                {
                    <div class="formal-report-witness-grid">
                        <label asp-for="Input.Witnesses[i].FullName" class="formal-report-line-label">Name:</label>
                        <div>
                            <input asp-for="Input.Witnesses[i].FullName" class="formal-report-underline" />
                            <span asp-validation-for="Input.Witnesses[i].FullName" class="text-danger"></span>
                        </div>

                        <label asp-for="Input.Witnesses[i].Email" class="formal-report-line-label">E-Mail:</label>
                        <div>
                            <input asp-for="Input.Witnesses[i].Email" class="formal-report-underline" />
                            <span asp-validation-for="Input.Witnesses[i].Email" class="text-danger"></span>
                        </div>
                    </div>
                }
            </section>

            <section class="formal-report-section">
                <p class="formal-report-routing-title">Submission Routing</p>
                <p class="formal-report-copy">
                    Upon submission, this form will be sent to:
                    <strong>Honor Council (honorcouncil@jmu.edu)</strong>,
                    the <strong>HC President</strong>, and the <strong>HC Coordinator</strong>.
                    Physical copies may also be delivered to Honor Council Office, MSC 7506.
                </p>

                <p class="formal-report-contact-title">Questions, please contact:</p>
                <p class="formal-report-copy" style="margin-bottom: 0;">
                    Masoud Kaveh-Baghbadorani, Honor Council Coordinator,<br />
                    <a href="mailto:kavehbmx@jmu.edu">kavehbmx@jmu.edu</a>, (540) 568-4173
                </p>

                <div class="formal-report-office-box">
                    <h3>Office Use Only:</h3>

                    <div class="formal-report-office-line">
                        <span>Received On:</span>
                        <div class="formal-report-office-fill"></div>
                    </div>

                    <div class="formal-report-office-line">
                        <span>Assigned On:</span>
                        <div class="formal-report-office-fill"></div>
                    </div>

                    <div class="formal-report-office-line">
                        <span>Investigator:</span>
                        <div class="formal-report-office-fill"></div>
                    </div>
                </div>
            </section>

            <div class="formal-report-actions">
                <button type="button" class="formal-report-button formal-report-button-secondary" disabled>Save Draft</button>
                <button type="submit" class="formal-report-button formal-report-button-primary">Submit Formal Report</button>
            </div>
        </form>
    </article>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const violationDateInput = document.getElementById("Input_ViolationDate");
            if (!violationDateInput) {
                return;
            }

            const validationMessage = violationDateInput.dataset.windowMessage || "Reports must be filed within 90 days of the violation date.";
            const earliestAllowedDate = violationDateInput.min;

            const validateViolationDate = () => {
                const selectedDate = violationDateInput.value;

                if (!selectedDate || !earliestAllowedDate || selectedDate >= earliestAllowedDate) {
                    violationDateInput.setCustomValidity("");
                    return;
                }

                violationDateInput.setCustomValidity(validationMessage);
                violationDateInput.reportValidity();
            };

            violationDateInput.addEventListener("change", validateViolationDate);
            violationDateInput.addEventListener("input", validateViolationDate);
        })();
    </script>
}
